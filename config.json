{
  "inbounds": [
    {
      "port": 8080,
      "protocol": "vless",
      "settings": {
        "clients": [{"id": "52a2859a-c704-4d35-aa6c-e44885e490c2", "level": 0}],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {
          "path": "/",
          "mode": "packet"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [{"protocol": "freedom"}],
  "routing": {
    "rules": [
      {
        "type": "field",
        "inboundTag": ["fallback"],
        "outboundTag": "local_html"
      }
    ]
  }
}